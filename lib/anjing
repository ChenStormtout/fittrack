```dart
import 'package:flutter/foundation.dart';

import '../../../core/services/secure_storage_service.dart';

class AuthController extends ChangeNotifier {
  AuthController(this._secureStorageService);

  final SecureStorageService _secureStorageService;

  bool _isLoggedIn = false;
  bool _isInitialized = false;
  String? _userEmail;

  bool get isLoggedIn => _isLoggedIn;
  bool get isInitialized => _isInitialized;
  String? get userEmail => _userEmail;

  Future<void> initialize() async {
    final token = await _secureStorageService.getSessionToken();
    final email = await _secureStorageService.getSessionEmail();

    _isLoggedIn = token != null && token.isNotEmpty;
    _userEmail = email;
    _isInitialized = true;
    notifyListeners();
  }

  Future<bool> login({required String email, required String password}) async {
    // Tahap awal: dummy login
    // Nanti diganti dengan validasi database + hashing password
    if (email.trim().isEmpty || password.trim().isEmpty) return false;

    await _secureStorageService.saveSession(
      token: 'dummy_session_token_${DateTime.now().millisecondsSinceEpoch}',
      email: email.trim(),
    );

    _isLoggedIn = true;
    _userEmail = email.trim();
    notifyListeners();
    return true;
  }

  Future<bool> register({
    required String email,
    required String password,
  }) async {
    // Tahap awal: dummy register
    // Nanti disambungkan ke local database
    if (email.trim().isEmpty || password.trim().isEmpty) return false;
    return true;
  }

  Future<void> logout() async {
    await _secureStorageService.clearSession();
    _isLoggedIn = false;
    _userEmail = null;
    notifyListeners();
  }
}
